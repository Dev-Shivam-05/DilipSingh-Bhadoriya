# ── Database ─────────────────────────────────────────────
# Local development (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Supabase/Neon Postgres) — also change provider in prisma/schema.prisma to "postgresql":
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Admin panel ──────────────────────────────────────────
# The family logs into /admin with this password. Use a long, unique one.
ADMIN_PASSWORD="change-me-strong-password"
# Random string used to sign the admin session cookie:
SESSION_SECRET="generate-a-long-random-string"

# ── Site ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
